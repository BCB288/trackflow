# TrackFlow Environment Configuration
NODE_ENV=production
PORT=3000

# Database
TRACKFLOW_DB_PATH=/app/data/trackflow.db

# Authentication (CHANGE THESE IN PRODUCTION)
JWT_SECRET=your-secure-random-secret-here
JWT_EXPIRES_IN=24h

# SMS Provider: 'console' (dev) or 'twilio' (production)
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_MAX_RETRIES=2
SMS_RETRY_DELAY_MS=1000
